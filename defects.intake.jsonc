      "category": "color",
      "tier": "low",
      "selector": "[data-testid=\"member-avatar\"]",
      "whatsWrong": "Header member avatars have mix-blend-multiply; the photos composite with the background. Can't be color-sampled, no token to grep. mix-blend-mode is multiply vs golden normal.",
      "checks": [{ "type": "computed-style", "target": "mix-blend-mode" }],
      "where": [
        { "screen": "kanban", "state": "default", "viewport": "desktop" },
