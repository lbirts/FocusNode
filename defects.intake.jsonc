  "clusters": [
    {
      "id": "daily-planner-entangled",
      "branch": "defect/cluster-1",
      "defects": [
        "c1-btn-height",
        "c1-card-pad",
        "c1-stat",
        "c1-separator",
        "c1-circle",
        "c1-font",
        "c1-autorank",
      ],
      "note": "Daily Planner: conservation splits + sub-component bugs (Stat/Separator) + font-fallback + an Auto-rank relocate-and-corrupt. Mutations leave no greppable outlier; partial fixes regress.",
    },
    {
      "id": "focus-timer-temporal",
      "branch": "defect/cluster-2",
      "defects": [
        "c2-tabnum",
        "c2-transition",
        "c2-blend",
        "c2-dial",
        "c2-ticklen",
        "c2-grid",
        "c2-controls",
      ],
      "note": "Focus Timer: an obvious broken preset layout (grid-cols-1 stack vs flex row) dominates the pixel diff while subtler defects survive - invisible-at-rest computed styles (tabular-nums, transition-none, mix-blend), two dial geometry bugs graded by bounding box (extra lit tick + ticks 3px short), and a reversed control row that only transposes Restart/Skip.",
    },
    {
      "id": "kanban-css-ghosts",
      "branch": "defect/cluster-3",
      "defects": [
        "c3-badge-blend",
        "c3-avatar-blend",
        "c3-card-border",
        "c3-col-stripe",
        "c3-first-letter",
        "c3-hairline",
        "c3-first-line",
        "c3-contrast",
      ],
      "note": "Kanban: causes hidden in machinery the model never greps - mix-blend, ::before/::after/::first-letter/::first-line, :nth-child - plus a relocate-and-corrupt card border and a WCAG AA contrast failure on the card titles whose cause is a subtree-scoped CSS custom-property re-bind on the card wrapper.",
    },
    {
      "id": "layout-engine-ambiguity",
      "branch": "defect/cluster-4",
      "defects": [
        "c4-swimlane-grid",
        "c4-task-grid",
        "c4-controls-grid",
        "c4-card-grid",
        "c4-stats-flex",
        "c4-kanban-header-order",
        "c4-planner-header-order",
      ],
      "note": "Mechanism ambiguity: every defect ships a BROKEN decoy layout engine (flex<->grid, or DOM-order vs flex-row-reverse). The pixel-fix that stays in the decoy renders identical to golden but computes a different display / grid-template-columns / flex-direction, so the computed-style pin (no accept = exact golden match) fails. Correct is the source mechanism, not the pixels - a model fixing from screenshots stays in the decoy engine and fails.",
    },
    {
      "id": "spacing-mechanism-ambiguity",
      "branch": "defect/cluster-5",
      "defects": [
        "c5-tasklist-gap",
        "c5-boards-gap",
        "c5-controls-gap",
        "c5-team-justify",
        "c5-footer-justify",
        "c5-colheader-justify",
        "c5-taskbody-fill",
      ],
      "note": "Mechanism ambiguity inside one flex layout: the gap is achieved by space-x/y child margins instead of gap; the edge-push by ml-auto instead of justify-between; the fill by basis-* instead of flex-1. Each renders pixel-identical but computes a different row/column-gap / justify-content / flex-basis, so the pin (no accept) fails. Correct is the source mechanism.",
    },
  ],
}
