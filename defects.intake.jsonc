      "checks": [{ "type": "computed-style", "target": "border-top-width" }],
      "where": [
        { "screen": "kanban", "state": "default", "viewport": "desktop" },
      ],
    },
    {
      "branch": "defect/cluster-3",
      "id": "c3-col-stripe",
      "category": "color",
      "tier": "low",
      "selector": "[data-testid=\"kanban-column-1\"]",
      "whatsWrong": "Columns have an `even:` (:nth-child) bg stripe; alternating columns are tinted with no per-element class. kanban-column-1 (2nd, even) background-color is primary-50 vs golden white.",
      "checks": [{ "type": "computed-style", "target": "background-color" }],
      "where": [
        { "screen": "kanban", "state": "default", "viewport": "desktop" },
      ],
    },
