    },
    {
      "branch": "defect/cluster-3",
      "id": "c3-first-line",
      "category": "typography",
      "tier": "low",
      "selector": "[data-testid=\"card-title\"]",
      "whatsWrong": "Card titles have `first-line:tracking-[0.06em]`; first-line letter-spacing is off via a ::first-line pseudo. ::first-line letter-spacing is ~0.84px vs golden normal.",
      "checks": [
        {
          "type": "computed-style",
