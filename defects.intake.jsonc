  // PINNED FAILING CLUSTERS
  "clusters": [
    {
      "id": "daily-planner-entangled",
      "branch": "defect/cluster-1",
      "defects": [
        "c1-btn-height",
        "c1-card-pad",
        "c1-stat",
        "c1-separator",
        "c1-circle",
        "c1-font",
        "c1-autorank",
      ],
      "note": "Daily Planner: conservation splits + sub-component bugs (Stat/Separator) + font-fallback + an Auto-rank relocate-and-corrupt. Mutations leave no greppable outlier; partial fixes regress.",
    },
    {
      "id": "focus-timer-temporal",
      "branch": "defect/cluster-2",
      "defects": [
        "c2-tabnum",
        "c2-transition",
        "c2-blend",
        "c2-pad",
        "c2-dial",
        "c2-ticklen",
        "c2-pause",
      ],
      "note": "Focus Timer: defects invisible to a static-frame diff (tabular-nums, transition, blend) plus running/paused-only logic bugs (padEnd, dial off-by-one + short ticks, broken pause).",
    },
    {
      "id": "kanban-css-ghosts",
      "branch": "defect/cluster-3",
      "defects": [
        "c3-badge-blend",
        "c3-avatar-blend",
        "c3-card-border",
        "c3-col-stripe",
        "c3-first-letter",
        "c3-hairline",
        "c3-first-line",
        "c3-add-card",
      ],
      "note": "Kanban: causes hidden in machinery the model never greps - mix-blend, ::before/::after/::first-letter/::first-line, :nth-child - plus a relocate-and-corrupt card border and a wrong-column Add-card behavioral bug.",
    },
  ],
}
